---
import { social } from '../data/site';

interface Props {
  variant?: 'inline' | 'grid';
}
const { variant = 'inline' } = Astro.props;

const items = [
  {
    href: social.spotify,
    label: 'Spotify',
    // Spotify glyph
    path: 'M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0Zm5.52 17.34a.75.75 0 0 1-1.03.25c-2.83-1.73-6.4-2.12-10.6-1.16a.75.75 0 1 1-.34-1.46c4.6-1.05 8.55-.6 11.72 1.34.36.22.47.69.25 1.03Zm1.47-3.27a.94.94 0 0 1-1.29.31c-3.24-1.99-8.18-2.57-12.01-1.4a.94.94 0 0 1-.55-1.79c4.39-1.34 9.84-.7 13.55 1.59.45.27.59.85.3 1.29Zm.13-3.41C15.24 8.4 8.6 8.18 4.92 9.3a1.13 1.13 0 0 1-.66-2.16c4.24-1.29 11.62-1.04 16.18 1.7.54.32.71 1.02.39 1.55-.32.54-1.02.71-1.7.27Z',
  },
  {
    href: social.youtube,
    label: 'YouTube',
    path: 'M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1c.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8ZM9.6 15.6V8.4l6.3 3.6-6.3 3.6Z',
  },
  {
    href: social.instagram,
    label: 'Instagram',
    path: 'M12 2.2c3.2 0 3.6 0 4.8.07 3.2.15 4.7 1.7 4.85 4.85.06 1.2.07 1.6.07 4.8s0 3.6-.07 4.8c-.15 3.2-1.7 4.7-4.85 4.85-1.2.06-1.6.07-4.8.07s-3.6 0-4.8-.07c-3.2-.15-4.7-1.7-4.85-4.85C2.21 15.6 2.2 15.2 2.2 12s0-3.6.07-4.8C2.42 4 3.97 2.5 7.12 2.35 8.4 2.21 8.8 2.2 12 2.2ZM12 0C8.74 0 8.33 0 7.05.07 2.7.27.27 2.7.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95C23.73 2.7 21.3.27 16.95.07 15.67.01 15.26 0 12 0Zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32Zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.4-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z',
  },
  {
    href: social.facebook,
    label: 'Facebook',
    path: 'M24 12a12 12 0 1 0-13.88 11.85v-8.38H7.08V12h3.04V9.41c0-3 1.79-4.66 4.53-4.66 1.31 0 2.69.23 2.69.23v2.95h-1.51c-1.49 0-1.95.93-1.95 1.87V12h3.32l-.53 3.47h-2.79v8.38A12 12 0 0 0 24 12Z',
  },
  {
    href: social.linktree,
    label: 'Linktree',
    path: 'M13.74 0H10.3v8.83l6.24-6.24 2.43 2.43L12.7 11.3h8.83v3.43h-8.83l6.27 6.28-2.43 2.43-6.24-6.27V24H10.3v-6.83l-6.24 6.27-2.43-2.43 6.27-6.28H-1v-3.43h8.9L1.63 5.02l2.43-2.43L10.3 8.83V0Z',
  },
];
---

<ul class={`social social--${variant}`} aria-label="Band on social media">
  {
    items.map((i) => (
      <li>
        <a
          href={i.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={i.label}
        >
          <svg
            viewBox="0 0 24 24"
            width="22"
            height="22"
            aria-hidden="true"
            focusable="false"
          >
            <path d={i.path} fill="currentColor" />
          </svg>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social a {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border);
    color: var(--ink-dim);
    transition: color 200ms var(--ease), border-color 200ms var(--ease),
      background 200ms var(--ease), transform 200ms var(--ease);
  }

  .social a:hover,
  .social a:focus-visible {
    color: var(--ink);
    background: var(--blood);
    border-color: var(--blood);
    transform: translateY(-2px);
  }

  .social--grid {
    gap: 0.6rem;
  }
</style>
