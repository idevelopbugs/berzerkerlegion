---
interface Props {
  /** Spotify URI fragment, e.g. 'artist/72MD4qOT5kUc5FMZ8eqxkX' or 'album/...' */
  uri: string;
  title?: string;
  height?: number;
}

const { uri, title = 'Spotify player', height = 352 } = Astro.props;
const src = `https://open.spotify.com/embed/${uri}?utm_source=generator&theme=0`;
---

<div class="spotify" style={`--h:${height}px`}>
  <iframe
    src={src}
    title={title}
    width="100%"
    height={height}
    loading="lazy"
    frameborder="0"
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    referrerpolicy="strict-origin-when-cross-origin"></iframe>
</div>

<style>
  .spotify {
    border: 1px solid var(--border);
    background: var(--bg-elev);
    /* Reserve exact space; prevent Spotify's iframe from nudging layout after load */
    height: var(--h);
    overflow: hidden;
    contain: layout paint;
  }
  .spotify iframe {
    display: block;
    width: 100%;
    height: 100%;
    background: transparent;
  }
</style>
