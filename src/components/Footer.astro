---
import SocialLinks from './SocialLinks.astro';
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <img
        src="/images/logo-white.png"
        alt=""
        width="56"
        height="56"
        loading="lazy"
        decoding="async"
      />
      <p class="footer__name">{site.name}</p>
      <p class="footer__tag">{site.tagline}</p>
    </div>

    <SocialLinks />

    <p class="footer__copy">
      © {year} {site.name}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: #050505;
    position: relative;
    z-index: 2;
    margin-top: 4rem;
  }

  .footer__inner {
    padding-block: 3rem;
    display: grid;
    gap: 1.5rem;
    text-align: center;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__brand img {
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  .footer__name {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    margin: 0;
    color: var(--ink);
  }

  .footer__tag {
    margin: 0;
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .footer__copy {
    margin: 0;
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
</style>
